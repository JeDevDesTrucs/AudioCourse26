  36:VariSineFilterDrone.cpp **** // â”€â”€â”€ Filter types (Encoder press cycles through these) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
  37:VariSineFilterDrone.cpp **** // Svf (State Variable Filter) computes LP/HP/BP/Notch simultaneously.
  38:VariSineFilterDrone.cpp **** // We use an enum to track which output we're reading.
  39:VariSineFilterDrone.cpp **** enum FilterMode {
  40:VariSineFilterDrone.cpp ****     FILTER_BYPASS = 0,  // no filter, raw oscillator signal
  41:VariSineFilterDrone.cpp ****     FILTER_LOWPASS,     // cuts highs, keeps lows â€” warm, dark
  42:VariSineFilterDrone.cpp ****     FILTER_HIGHPASS,    // cuts lows, keeps highs â€” thin, airy
  43:VariSineFilterDrone.cpp ****     FILTER_BANDPASS,    // keeps a band in the middle â€” nasal, telephone
  44:VariSineFilterDrone.cpp ****     FILTER_NOTCH,       // cuts a band in the middle â€” hollow, phasy
  45:VariSineFilterDrone.cpp ****     FILTER_NUM_MODES    // not a real mode â€” just counts how many we have
  46:VariSineFilterDrone.cpp **** };
  47:VariSineFilterDrone.cpp **** 
  48:VariSineFilterDrone.cpp **** // LED colors for each filter mode on LED 1 (LED 2 keeps waveform color)
  49:VariSineFilterDrone.cpp **** static const float kFilterColors[FILTER_NUM_MODES][3] = {
  50:VariSineFilterDrone.cpp ****     {1.0f, 1.0f, 1.0f},  // BYPASS    â†’ white
  51:VariSineFilterDrone.cpp ****     {0.0f, 0.0f, 1.0f},  // LOWPASS   â†’ blue  (warm/dark = cool color)
  52:VariSineFilterDrone.cpp ****     {1.0f, 0.5f, 0.0f},  // HIGHPASS  â†’ orange (bright/sharp = warm color)
  53:VariSineFilterDrone.cpp ****     {0.0f, 1.0f, 0.0f},  // BANDPASS  â†’ green
  54:VariSineFilterDrone.cpp ****     {1.0f, 0.0f, 0.5f},  // NOTCH     â†’ pink
  55:VariSineFilterDrone.cpp **** };
